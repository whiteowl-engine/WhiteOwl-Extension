        "https://*.magiceden.io/*",
        "https://magiceden.com/*",
        "https://*.magiceden.com/*",
        "https://tensor.trade/*",
        "https://*.tensor.trade/*",
        "https://backpack.app/*",
        "https://*.backpack.app/*",
        "https://backpack.exchange/*",
        "https://*.backpack.exchange/*",
