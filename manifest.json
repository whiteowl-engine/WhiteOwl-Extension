        "https://kamino.finance/*",
        "https://*.kamino.finance/*",
        "https://bullx.io/*",
        "https://*.bullx.io/*",
        "https://photon-sol.tinyastro.io/*",
        "https://defined.fi/*",
        "https://*.defined.fi/*"
      ],
      "js": ["provider.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://axiom.trade/*",
        "https://*.axiom.trade/*",
