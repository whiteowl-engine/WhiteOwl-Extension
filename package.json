    "content.js",
    "ex.mp4",
    "i18n-ext.js",
    "icon128.png",
    "icon16.png",
    "icon48.png",
    "lightweight-charts.js",
    "logo.png",
    "manifest.json",
    "owl.svg",
    "provider.js",
    "result_transparent.webm",
    "screenshots",
    "sidepanel.css",
    "sidepanel.html",
    "sidepanel.js",
    "swap-progress.webm"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
